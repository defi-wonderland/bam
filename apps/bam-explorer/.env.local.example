# Build-time defaults baked into the JS bundle. Each viewer can
# override these in their browser via the Settings panel.
NEXT_PUBLIC_DEFAULT_READER_URL=http://localhost:8788
NEXT_PUBLIC_DEFAULT_POSTER_URL=http://localhost:8787
NEXT_PUBLIC_DEFAULT_CONTENT_TAGS=                  # comma-separated 0x-prefixed bytes32 tags

# DELIBERATELY NOT EXPOSED:
# - There is no NEXT_PUBLIC_DEFAULT_POSTER_AUTH_TOKEN. A bearer token
#   would otherwise ship to every visitor of a deployed Explorer.
#   Tokens are entered per-viewer via Settings only.
