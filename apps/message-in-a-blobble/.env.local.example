NEXT_PUBLIC_RPC_URL=              # Sepolia execution RPC (Alchemy/Infura)
NEXT_PUBLIC_BAM_CORE_ADDRESS=     # BlobAuthenticatedMessagingCore address (Sepolia: 0x9C4b230066a6808D83F5FBa0c040E0Df2Fcc7314)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # RainbowKit
POSTER_URL=http://localhost:8787  # URL of a running @bam/poster instance; API routes proxy to it.
POSTER_PRIVATE_KEY=               # Poster signer private key (fund with Sepolia ETH) — used by the separately-run @bam/poster process
BEACON_API_URL=                   # Beacon chain API for blob retrieval (e.g. https://eth-sepoliabeacon.g.alchemy.com/v2/YOUR_KEY)
# POSTGRES_URL=                   # Set automatically by Vercel Postgres — uses SQLite locally when unset
