NEXT_PUBLIC_RPC_URL=              # Sepolia execution RPC (Alchemy/Infura)
NEXT_PUBLIC_BAM_CORE_ADDRESS=     # BlobAuthenticatedMessagingCore address (Sepolia: 0x9C4b230066a6808D83F5FBa0c040E0Df2Fcc7314)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # RainbowKit
POSTER_URL=http://localhost:8787  # URL of a running @bam/poster instance; API routes proxy to it.
READER_URL=http://localhost:8788  # URL of a running bam-reader instance; API routes proxy to it.
# POSTER_SIGNER_PRIVATE_KEY=      # NOT consumed by this demo — these POSTER_* vars are the
# POSTER_SIGNATURE_REGISTRY=      # @bam/poster process's env. Pass the Sepolia ECDSA registry
                                  # (0xF4Ce909305a112C2CBEC6b339a42f34bA8bf3381) so indexers can
                                  # verify this app's messages end-to-end. Documented here so a
                                  # local-dev `.env.local` is self-contained when running
                                  # `pnpm dev` (which spawns both processes). See packages/bam-poster/README.md.
# POSTER_BATCH_ENCODING=binary    # Wire format for posted batches.
                                  # `binary` (default): packed binary codec, decoded in the Reader's JS.
                                  # `abi`: ERC-8180 v1 ABI shape, decoded by the on-chain ABIDecoder
                                  #   (Sepolia: 0x3a1bB111079cBaF4CAc320545Bfd1f6A92250425).
                                  # On `abi`, the Poster resolves the decoder address from
                                  # packages/bam-contracts/deployments/<chainId>.json; missing entry
                                  # → EnvConfigError at boot. Casing is exact ({binary|abi}, no aliases).

# Reader scan ergonomics (optional)
# Defaults work against the public Sepolia provider used by the demo;
# raise / lower these only when an operator scenario requires it.
# READER_START_BLOCK=               # Override first-tick block. Default: BAM Core deploy block
                                    # for the configured chainId (10697923 on Sepolia); falls back
                                    # to 0 with a stderr warning on chains not in the deploy table.
# READER_LOG_SCAN_CHUNK_BLOCKS=2000 # eth_getLogs chunk size. Adaptive halving recovers from
                                    # "range too large" / "result too large" automatically.
# READER_BACKFILL_PROGRESS_INTERVAL_MS=10000  # Min wallclock interval between backfill_progress events.
# READER_BACKFILL_PROGRESS_EVERY_CHUNKS=5     # Alternative cadence trigger; whichever fires first wins.
