NEXT_PUBLIC_RPC_URL=              # Sepolia execution RPC (Alchemy/Infura)
NEXT_PUBLIC_BAM_CORE_ADDRESS=     # BlobAuthenticatedMessagingCore address (Sepolia: 0x9C4b230066a6808D83F5FBa0c040E0Df2Fcc7314)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # RainbowKit
POSTER_URL=http://localhost:8787  # URL of a running @bam/poster instance; API routes proxy to it.
# POSTER_SIGNER_PRIVATE_KEY=      # NOT consumed by this demo — these POSTER_* vars are the
# POSTER_SIGNATURE_REGISTRY=      # @bam/poster process's env. Pass the Sepolia ECDSA registry
                                  # (0xF4Ce909305a112C2CBEC6b339a42f34bA8bf3381) so indexers can
                                  # verify this app's messages end-to-end. Documented here so a
                                  # local-dev `.env.local` is self-contained when running
                                  # `pnpm dev` (which spawns both processes). See packages/bam-poster/README.md.
BEACON_API_URL=                   # Beacon chain API for blob retrieval (e.g. https://eth-sepoliabeacon.g.alchemy.com/v2/YOUR_KEY)
# BAM_STORE_POSTGRES_URL=         # Postgres connection string for the shared bam-store substrate (Reader populates `confirmed` rows here). Falls back to in-process PGLite when unset.
# POSTGRES_URL=                   # Vercel-managed Postgres — also recognized as the bam-store backend when set.
