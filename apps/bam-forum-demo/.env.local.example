# ──────────────────────────────────────────────────────────────────────────
# Client-side (public — bundled into the browser). Required.
# ──────────────────────────────────────────────────────────────────────────

# Sepolia execution RPC used by wagmi (Alchemy / Infura / pokt).
NEXT_PUBLIC_RPC_URL=

# WalletConnect Cloud project ID for RainbowKit.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ──────────────────────────────────────────────────────────────────────────
# Server-side (kept out of the bundle). Required.
# ──────────────────────────────────────────────────────────────────────────

# Default deployment is on fly.io.
POSTER_URL=https://bam-poster.fly.dev
READER_URL=https://bam-reader.fly.dev
COPROCESSOR_URL=https://bam-coprocessor.fly.dev

# Mainnet RPC for server-side ENS resolution.
# Unset = forum still works, just no ENS names (truncated 0xabcd…1234 only).
MAINNET_RPC_URL=

# ──────────────────────────────────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────────────────────────────────

# Bearer token forwarded to the poster /submit endpoint when it requires auth.
# POSTER_AUTH_TOKEN=

# Override the forum content tag (defaults to FORUM_TAG from bam-sdk/forum).
# Only used by tests against a non-prod tag space.
# FORUM_CONTENT_TAG=
