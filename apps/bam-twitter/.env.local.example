NEXT_PUBLIC_RPC_URL=              # Sepolia execution RPC (Alchemy/Infura)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=  # RainbowKit
POSTER_URL=http://localhost:8787  # Shared @bam/poster instance; same one the message-in-a-blobble demo uses
READER_URL=http://localhost:8788  # Shared bam-reader instance; same one the message-in-a-blobble demo uses
INDEXER_URL=http://localhost:8789 # Optional. When set, /api/confirmed-messages prefers bam-indexer's app-shaped /twitter/posts (decoded server-side, ENS resolved). Unset = Reader-only path.
