# Sepolia RPC URL (required — public RPCs don't reliably support EIP-4844)
NEXT_PUBLIC_RPC_URL=

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server wallet private key for posting blob transactions (must have Sepolia ETH)
POSTER_PRIVATE_KEY=

# Beacon API URL for blob fetching (optional, falls back to Blobscan)
BEACON_API_URL=
