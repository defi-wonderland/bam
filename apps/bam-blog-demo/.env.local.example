# Shared Poster + Reader URLs.
# Local stack defaults (matches `pnpm dev` from the workspace root):
POSTER_URL=http://localhost:8787
READER_URL=http://localhost:8788
# Or point at the live fly.dev deployment to demo without running
# the Poster/Reader locally:
#   POSTER_URL=https://bam-poster.fly.dev
#   READER_URL=https://bam-reader.fly.dev

# Port for this demo's static + proxy server.
PORT=3002
