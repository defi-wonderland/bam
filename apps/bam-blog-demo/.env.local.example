# Build-time env vars consumed by the comments widget
# (`src/widget/poster-reader.ts`). Both must be set; Vite bakes
# them into the bundle at `vite build`.
#
# This app has no Node server — `vite dev` and `vite build`
# produce a fully static deploy. The widget calls these URLs
# directly from the browser, so the upstream services must
# either send `Access-Control-Allow-Origin: *` (or whitelist the
# deploy origin).
VITE_POSTER_URL=https://bam-poster.fly.dev
VITE_READER_URL=https://bam-reader.fly.dev
