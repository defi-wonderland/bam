# Workspace-root env template for the long-running backend services
# (`@bam/poster`, `bam-reader`, and `bam-indexer`).
#
# Copy to `.env.local` (preferred — matches repo convention) or `.env`
# and fill in real values. Each service's CLI walks up from its cwd
# looking for either name; `.env.local` wins within a directory.
#
#   cp .env.local.example .env.local
#   pnpm dev
#
# This file is for the *backend* Node services. The Next.js demo app
# reads a separate file at `apps/message-in-a-blobble/.env.local` —
# see `apps/message-in-a-blobble/.env.local.example`.

# ═════════════════════════════════════════════════════════════════
# @bam/poster (long-running submission service, default :8787)
# ═════════════════════════════════════════════════════════════════

# ── Required ───────────────────────────────────────────────────────

# CSV of bytes32 content tags the Poster accepts. The demo's tag is
# keccak256("message-in-a-blobble.v1").
POSTER_ALLOWED_TAGS=0x323eee4675c068805a324c1a3a36805d446179434138f2f0872ac3f81b2e6591

# Target chain. 11155111 = Sepolia.
POSTER_CHAIN_ID=11155111

# Amended ERC-8180 BlobAuthenticatedMessagingCore deployment
# (includes the registerBlobBatches entrypoint for cross-tag packing).
POSTER_BAM_CORE_ADDRESS=0xC572A7F6dba1f3cB666b14d357671903685BeDdb

# Execution-layer RPC that supports EIP-4844 blob txs. Public RPCs
# often don't; Alchemy/Infura/QuickNode with the proper plan do.
POSTER_RPC_URL=

# 32-byte hex private key for the signer. FUND WITH Sepolia ETH —
# every blob tx burns gas + blob gas.
POSTER_SIGNER_PRIVATE_KEY=

# ── Optional ───────────────────────────────────────────────────────

# ERC-8180 scheme-0x01 ECDSA registry. Without it, indexers treat the
# batch as unregistered (address(0)). Sepolia deployment below.
POSTER_SIGNATURE_REGISTRY=0xF4Ce909305a112C2CBEC6b339a42f34bA8bf3381

# HTTP listen binding (defaults: 127.0.0.1:8787).
# POSTER_HOST=127.0.0.1
# POSTER_PORT=8787

# Storage. In-process PGLite locally if unset — state is non-durable
# and the CLI logs a stderr warning on startup. Set POSTGRES_URL to a
# real Postgres for any deploy that needs durability. For local dev
# with shared state (Poster + Reader converge on one DB), spin up the
# workspace's Docker Postgres with `pnpm db:up` and uncomment the
# line below. The Reader's READER_DB_URL (further down) should point
# at the same DSN so both services see the same `confirmed` rows.
# POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/bam

# Bearer-token auth for the HTTP surface. When set, every request
# must carry `Authorization: Bearer <token>`. Leave unset for local
# dev; required in production behind anything other than a private
# reverse proxy.
# POSTER_AUTH_TOKEN=

# Reorg tolerance window, in L1 blocks. Clamped [4, 128]; default 32.
# POSTER_REORG_WINDOW_BLOCKS=32

# Wire format for posted batches. Casing is exact ({binary|abi}, no aliases).
# - `binary` (default): packed binary codec, decoded in the Reader's JS;
#   the decoder field on `registerBlobBatch` is set to zeroAddress.
# - `abi`: ERC-8180 v1 ABI shape; the decoder address is resolved from
#   `packages/bam-contracts/deployments/<chainId>.json` at boot. Missing
#   entry → EnvConfigError. Manual override is not supported.
# POSTER_BATCH_ENCODING=binary

# ═════════════════════════════════════════════════════════════════
# bam-reader (long-running L1-tailing service, default :8788)
# ═════════════════════════════════════════════════════════════════
#
# The Reader observes BlobBatchRegistered events on L1, fetches and
# verifies blob bytes, and writes confirmed rows into the same
# bam-store the Poster writes pending/submitted rows into. Most
# values mirror the Poster's — they're the same chain, contract, and
# database — but they're separate env vars so the two processes can
# diverge if you ever need to (e.g. point the Reader at a different
# RPC for reads only).

# ── Required ───────────────────────────────────────────────────────

# Target chain. The Reader cross-checks this against POSTER_CHAIN_ID
# at startup when both vars are present and refuses to start on
# mismatch — pointing them at different chains would cross-write the
# shared substrate. 11155111 = Sepolia.
READER_CHAIN_ID=11155111

# Execution-layer RPC. Read-only operations only (eth_getLogs,
# eth_getBlockByNumber, eth_call). A separate read-only key works fine.
READER_RPC_URL=

# Same BAM Core address the Poster uses.
READER_BAM_CORE=0xC572A7F6dba1f3cB666b14d357671903685BeDdb

# ── Optional: bam-store DSN ────────────────────────────────────────
#
# Resolution order (first match wins):
#   1. READER_DB_URL — explicit Reader-side override (uncomment below).
#   2. POSTGRES_URL  — the workspace shared DSN above. The default
#      reuses it so a `pnpm db:up` checkout doesn't need two copies of
#      the same connection string.
#   3. memory:       — in-process PGLite, ephemeral. The Reader logs a
#      stderr warning at startup ("non-durable across restarts").
#
# Uncomment the line below to point the Reader at a Postgres distinct
# from the Poster's (e.g. a read-replica DSN). Leave it commented for
# the standard shared-DB topology.
# READER_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/bam

# ── Blob source (at least one recommended) ─────────────────────────
#
# To decode message contents from a confirmed batch, the Reader
# needs to fetch the raw blob bytes. It tries beacon first (when
# configured + a parent beacon block root is available), Blobscan
# as fallback. *Either alone is sufficient.* With neither, the
# Reader still observes batch metadata (txHash, blockNumber,
# blobVersionedHash) but cannot decode contents — the demo's
# message timeline stays empty.
#
# For "just make it work on Sepolia without a provider key,"
# uncomment the Blobscan line below; it's a public endpoint.

# Public Sepolia Blobscan archive — no auth, retains older blobs,
# higher latency than a beacon node. The Reader recomputes the
# versioned hash on the returned bytes and rejects mismatches,
# so a lying Blobscan doesn't poison the substrate.
# READER_BLOBSCAN_URL=https://api.sepolia.blobscan.com

# Beacon API for blob retrieval. Lower latency than Blobscan but
# blobs age out at the consensus retention window (~18 days on
# mainnet, less on testnets). Provider-gated.
# READER_BEACON_URL=https://eth-sepoliabeacon.g.alchemy.com/v2/YOUR_KEY

# CSV of bytes32 content tags to follow. Empty / unset → follow all
# tags. Narrowing the list now only changes which tags this Reader
# decodes — the demo's `/api/next-nonce` reads the Poster's
# `/nonce/<sender>` directly, so it no longer depends on the Reader
# seeing every tag the Poster serves.
# READER_CONTENT_TAGS=0x323eee4675c068805a324c1a3a36805d446179434138f2f0872ac3f81b2e6591

# HTTP listen binding (defaults: 127.0.0.1:8788). Loopback by default
# per red-team C-1; widen explicitly for a deploy fronting auth at a
# reverse proxy.
# READER_HTTP_BIND=127.0.0.1
# READER_HTTP_PORT=8788

# Reorg tolerance window, in L1 blocks. Clamped [4, 128]; default 32.
# READER_REORG_WINDOW_BLOCKS=32

# eth_call gas cap and timeout for the Reader's verify-dispatch path.
# Tune up if you point the Reader at a chain with slow eth_call.
# READER_ETH_CALL_GAS_CAP=50000000
# READER_ETH_CALL_TIMEOUT_MS=5000

# ═════════════════════════════════════════════════════════════════
# bam-indexer (long-running projection service, default :8789)
# ═════════════════════════════════════════════════════════════════
#
# The Indexer consumes confirmed messages from bam-store, projects
# per-contentTag entities via in-tree handlers, and serves a read
# REST API per handler (e.g. `/twitter/posts`). Sits above bam-reader
# (protocol-level decode → store) and below per-FE BFFs (response
# shaping). Not a required dependency of any BAM app — every
# client-facing surface declares a bam-reader fallback per the
# constitution's degraded-mode requirement.

# ── Required ───────────────────────────────────────────────────────

# Target chain. 11155111 = Sepolia. Cross-filters every `messages` /
# `batches` read.
INDEXER_CHAIN_ID=11155111

# Read DSN for bam-store's `messages` + `batches` tables. The value
# below works against the workspace's Docker Postgres (`pnpm db:up`).
# For Fly deploys, scripts/fly-set-secrets.sh always force-sets this
# from FLY_POSTGRES_URL — any value here is ignored in that path so
# a local-dev DSN can't silently stage onto prod.
INDEXER_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/bam

# 0x-prefixed 32-byte hex — the `contentTag` the post-reply handler
# registers for. Production value below is `keccak256("bam-twitter.v1")`;
# the bam-twitter UI hardcodes the same constant in
# apps/bam-twitter/src/lib/constants.ts and the two MUST match or
# the feed renders empty.
INDEXER_TWITTER_TAG=0xf0fea94ffd2ae32ed878c57e3427bbffab46d333d09837bc640d952795090718

# ── Optional ───────────────────────────────────────────────────────

# Write DSN for the indexer's own schemas (`indexer.*`, `twitter.*`).
# Falls back to INDEXER_DB_URL when unset — fine for single-role
# deployments. Set explicitly for the read/write role split: grant the
# bam_indexer user SELECT on bam-store tables and ALL on the indexer
# schemas. See packages/bam-indexer/README.md for the DDL.
# INDEXER_WRITE_DB_URL=

# Tick cadence (ms) and rows pulled per handler per tick. Defaults shown.
# INDEXER_POLL_MS=5000
# INDEXER_BATCH_SIZE=200

# HTTP listen binding (defaults: 127.0.0.1:8789). Loopback by default
# per red-team C-1; widen explicitly for a deploy fronting auth at a
# reverse proxy. fly.indexer.toml overrides this to 0.0.0.0.
# INDEXER_HTTP_BIND=127.0.0.1
# INDEXER_HTTP_PORT=8789
