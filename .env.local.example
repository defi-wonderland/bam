# Workspace-root env template for the @bam/poster service.
#
# Copy to `.env.local` (preferred — matches repo convention) or `.env`
# and fill in real values. The Poster CLI walks up from its cwd
# looking for either name; `.env.local` wins within a directory.
#
#   cp .env.local.example .env.local
#   pnpm dev
#
# This file is for the *Poster* (Node service). The Next.js demo app
# reads a separate file at `apps/message-in-a-blobble/.env.local` —
# see `apps/message-in-a-blobble/.env.local.example`.

# ── Required ───────────────────────────────────────────────────────

# CSV of bytes32 content tags the Poster accepts. The demo's tag is
# keccak256("message-in-a-blobble.v1").
POSTER_ALLOWED_TAGS=0x323eee4675c068805a324c1a3a36805d446179434138f2f0872ac3f81b2e6591

# Target chain. 11155111 = Sepolia.
POSTER_CHAIN_ID=11155111

# Amended ERC-8180 BlobAuthenticatedMessagingCore deployment.
POSTER_BAM_CORE_ADDRESS=0x9C4b230066a6808D83F5FBa0c040E0Df2Fcc7314

# Execution-layer RPC that supports EIP-4844 blob txs. Public RPCs
# often don't; Alchemy/Infura/QuickNode with the proper plan do.
POSTER_RPC_URL=

# 32-byte hex private key for the signer. FUND WITH Sepolia ETH —
# every blob tx burns gas + blob gas.
POSTER_SIGNER_PRIVATE_KEY=

# ── Optional ───────────────────────────────────────────────────────

# ERC-8180 scheme-0x01 ECDSA registry. Without it, indexers treat the
# batch as unregistered (address(0)). Sepolia deployment below.
POSTER_SIGNATURE_REGISTRY=0xF4Ce909305a112C2CBEC6b339a42f34bA8bf3381

# HTTP listen binding (defaults: 127.0.0.1:8787).
# POSTER_HOST=127.0.0.1
# POSTER_PORT=8787

# Storage. In-process PGLite locally if unset — state is non-durable
# and the CLI logs a stderr warning on startup. Set POSTGRES_URL to a
# real Postgres for any deploy that needs durability.
# POSTGRES_URL=

# Bearer-token auth for the HTTP surface. When set, every request
# must carry `Authorization: Bearer <token>`. Leave unset for local
# dev; required in production behind anything other than a private
# reverse proxy.
# POSTER_AUTH_TOKEN=

# Reorg tolerance window, in L1 blocks. Clamped [4, 128]; default 32.
# POSTER_REORG_WINDOW_BLOCKS=32

# Decoder + signature-registry addresses passed to registerBlobBatch.
# Default to zeroAddress; set the registry above for ECDSA verification.
# POSTER_DECODER_ADDRESS=0x0000000000000000000000000000000000000000
