{
  "name": "bam-cli",
  "version": "0.1.0",
  "description": "CLI for the BAM (Blob Authenticated Messaging) SDK",
  "type": "module",
  "main": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "bam": "dist/esm/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "lint": "eslint src"
  },
  "dependencies": {
    "bam-sdk": "workspace:*",
    "incur": "^0.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
