{
  "name": "bam-app-codecs",
  "version": "0.1.0",
  "description": "Application-level `contents` codecs for BAM (Blob Authenticated Messaging) apps. Protocol-level codecs live in `bam-sdk`; this package owns the per-app payload shape inside the `contents` field. Browser-safe.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./twitter": {
      "import": "./dist/esm/twitter/index.js",
      "types": "./dist/types/twitter/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest --run",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "bam-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
